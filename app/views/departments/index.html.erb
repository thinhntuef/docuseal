<div class="flex-wrap space-y-4 md:flex md:flex-nowrap md:space-y-0 md:space-x-10">
  <%= render 'shared/settings_nav' %>
  <div class="md:flex-grow">
    <div class="flex flex-col md:flex-row md:flex-wrap gap-2 md:justify-between md:items-end mb-4 min-h-12">
      <h1 class="text-4xl font-bold">
        <%= t('departments') %>
      </h1>
      <div class="flex flex-col md:flex-row gap-y-2 gap-x-4 md:items-center">
        <% if can?(:create, Department.new(account: current_account)) %>
          <%= link_to new_department_path, class: 'btn btn-primary btn-md gap-2 w-full md:w-fit', data: { turbo_frame: 'modal' } do %>
            <%= svg_icon('plus', class: 'w-6 h-6') %>
            <span><%= t('new_department') %></span>
          <% end %>
        <% end %>
      </div>
    </div>
    <p class="mb-4 text-base-content/70">
      <%= t('departments_description') %>
    </p>
    <% if @departments.present? %>
      <div class="overflow-x-auto">
        <table class="table w-full table-lg rounded-b-none overflow-hidden">
          <thead class="bg-base-200">
            <tr class="text-neutral uppercase">
              <th><%= t('name') %></th>
              <th><%= t('users') %></th>
              <th class="text-right" width="1px"></th>
            </tr>
          </thead>
          <tbody>
            <% @departments.each do |department| %>
              <tr scope="row">
                <td><%= department.name %></td>
                <td><%= department.users.size %></td>
                <td class="flex items-center space-x-2 justify-end">
                  <% if can?(:update, department) %>
                    <%= link_to edit_department_path(department), class: 'btn btn-outline btn-xs', title: t('edit'), data: { turbo_frame: 'modal' } do %>
                      <%= t('edit') %>
                    <% end %>
                  <% end %>
                  <% if can?(:destroy, department) %>
                    <%= button_to department_path(department), method: :delete, class: 'btn btn-outline btn-error btn-xs', title: t('remove'), data: { turbo_confirm: t('are_you_sure_') } do %>
                      <%= t('remove') %>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @pagy.pages > 1 %>
        <%= render 'shared/pagination', pagy: @pagy, items_name: 'departments' %>
      <% end %>
    <% else %>
      <div class="alert">
        <%= svg_icon('info_circle', class: 'w-6 h-6') %>
        <span><%= t('no_departments_yet') %></span>
      </div>
    <% end %>
  </div>
</div>
