<%= form_for department, html: { class: 'space-y-4' }, data: { turbo_frame: :_top } do |f| %>
  <div class="form-control">
    <%= f.label :name, t('name'), class: 'label' %>
    <%= f.text_field :name, required: true, autofocus: true, class: 'base-input', dir: 'auto' %>
  </div>
  <div class="form-control pt-2">
    <%= f.button button_title, class: 'base-button' %>
  </div>
<% end %>
